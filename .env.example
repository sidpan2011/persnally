# Persnally — Environment Variables
# v2 is local-first; everything here is optional.

# ── persnallyd (the engine) ──────────────────────
# Used for import extraction + profile synthesis. Optional: run fully local with
# Ollama instead, or set it for the background daemon via `persnallyd config set-key`.
ANTHROPIC_API_KEY=sk-ant-...

# ── web (marketing site) — put in web/.env.local ─
# Optional: OpenPanel analytics public client id.
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=
