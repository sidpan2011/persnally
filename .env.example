# Persnally — Environment Variables
# Copy this file to .env and fill in your values

# ── AI APIs ──────────────────────────────────────
# Required: Used for digest content curation
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Legacy support (being phased out)
OPENAI_API_KEY=sk-...

# ── Email (Resend) ───────────────────────────────
# Required: Used to send digest emails
RESEND_API_KEY=re_...

# ── GitHub ───────────────────────────────────────
# Optional: Used for GitHub-based content sourcing
GITHUB_TOKEN=ghp_...

# ── Supabase ─────────────────────────────────────
# Required for API: Database and authentication
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── App Config ───────────────────────────────────
# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# API port (default: 8000)
API_PORT=8000
