# Web Dashboard — Environment Variables
# Copy this file to .env.local and fill in your values

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_API_URL=http://localhost:8000

# OpenPanel analytics — public client id (safe in the browser). Required for
# analytics to load; if unset, the OpenPanel component is skipped.
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=your-openpanel-client-id
