{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "outDir": "build",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": ["src/**/*", "test/**/*"]
}
